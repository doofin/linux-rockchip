};

#ifdef FF_HDMI0
&hdmi0 {
	enable-gpios = <&gpio4 RK_PA0 GPIO_ACTIVE_HIGH>;
	status = "disabled";
};

&hdmi0_in_vp0 {
	status = "okay";
};
&hdmi0_in_vp1 {
	status = "disabled";
};
&hdmi0_in_vp2 {
	status = "disabled";
};

&i2s5_8ch {
	status = "okay";
};

&hdptxphy_hdmi0 {
	status = "okay";
};

&route_hdmi0{
	status = "okay";
	connect = <&vp0_out_hdmi0>;
};
#endif

#ifdef FF_HDMI1
&hdmi1 {
